# Auto detect text files and perform LF normalization
* text=auto

# Java sources
*.java text diff=java
*.gradle text diff=java
*.gradle.kts text diff=java

# Maven
pom.xml text diff=java

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Docker
Dockerfile text

# Markdown and docs
*.md text diff=markdown
*.txt text

# Properties and config
*.properties text
*.yml text
*.yaml text
*.json text

# Binary files
*.jar binary
*.class binary
*.exec binary

# Archives
*.zip binary
*.tar binary
*.gz binary
